-- [TIME-BASED GREETING LOGIC]
local function getGreeting()
    local hour = os.date("*t").hour
    local msg = "Hello User"
    if hour >= 5 and hour < 12 then
        -- Morning
    elseif hour >= 12 and hour < 18 then
        -- Noon
    end
    return msg
end

