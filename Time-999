-- [DRAGGABLE PHILIPPINES TIME UI]
local function CreateTimeUI()
    local sg = Instance.new("ScreenGui", game.CoreGui)
    sg.Name = "PH_Time_Overlay"
    sg.ResetOnSpawn = false

    local frame = Instance.new("Frame", sg)
    frame.Size = UDim2.new(0, 150, 0, 40)
    frame.Position = UDim2.new(0, 10, 0, 50) 
    frame.BackgroundColor3 = Color3.fromRGB(25, 25, 25)
    frame.BackgroundTransparency = 0.3
    frame.BorderSizePixel = 0
    frame.Active = true
    frame.Draggable = true 
    Instance.new("UICorner", frame).CornerRadius = UDim.new(0, 8)

    local tLabel = Instance.new("TextLabel", frame)
    tLabel.Size = UDim2.new(1, 0, 1, 0)
    tLabel.BackgroundTransparency = 1
    tLabel.TextColor3 = Color3.fromRGB(255, 140, 0)
    tLabel.TextSize = 16
    tLabel.Font = Enum.Font.GothamBold
    tLabel.Text = "PH Time: 00:00 AM"

    task.spawn(function()
        while true do
            local d = os.date("*t")
            local ampm = d.hour >= 12 and "PM" or "AM"
            local h = d.hour % 12
            if h == 0 then h = 12 end
            tLabel.Text = string.format("PH Time: %02d:%02d %s", h, d.min, ampm)
            task.wait(1)
        end
    end)
end

CreateTimeUI()

